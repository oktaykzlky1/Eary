{
  "rules": {
    ".read": false,
    ".write": false,
    "authUsers": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "publicProfiles": {
      ".read": true,
      "$username": {
        ".write": "auth != null && root.child('authUsers').child(auth.uid).child('username').val() === $username || !data.exists()"
      }
    },
    "users": {
      "$username": {
        "profile": {
          ".read": true,
          ".write": "auth != null && root.child('authUsers').child(auth.uid).child('username').val() === $username || !data.exists()"
        },
        "history": {
          ".read": "auth != null && root.child('authUsers').child(auth.uid).child('username').val() === $username || root.child('publicProfiles').child($username).exists()",
          ".write": "auth != null || root.child('publicProfiles').child($username).exists()"
        },
        "pushTokens": {
          ".read": "auth != null && root.child('authUsers').child(auth.uid).child('username').val() === $username",
          ".write": "auth != null && root.child('authUsers').child(auth.uid).child('username').val() === $username"
        },
        "$other": {
          ".read": "auth != null && root.child('authUsers').child(auth.uid).child('username').val() === $username",
          ".write": "auth != null && root.child('authUsers').child(auth.uid).child('username').val() === $username"
        }
      }
    },
    "phoneDirectory": {
      ".read": "auth != null",
      "$phoneHash": {
        ".write": "auth != null"
      }
    },
    "adminUsers": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": false
      }
    },
    "adminTasks": {
      ".read": false,
      ".write": false
    },
    "contacts": {
      "$username": {
        "$otherUsername": {
          ".read": "auth != null || root.child('publicProfiles').child($username).exists()",
          ".write": "auth != null || root.child('publicProfiles').child($username).exists()"
        }
      }
    },
    "messageRequests": {
      "$username": {
        ".read": "auth != null || root.child('publicProfiles').child($username).exists()",
        ".write": "auth != null || root.child('publicProfiles').child($username).exists()"
      }
    },
    "sentMessageRequests": {
      "$username": {
        ".read": "auth != null || root.child('publicProfiles').child($username).exists()",
        ".write": "auth != null || root.child('publicProfiles').child($username).exists()"
      }
    },
    "acceptanceNotices": {
      "$username": {
        ".read": "auth != null || root.child('publicProfiles').child($username).exists()",
        ".write": "auth != null || root.child('publicProfiles').child($username).exists()"
      }
    },
    "rooms": {
      "$roomId": {
        ".read": true,
        ".write": "auth != null || data.child('members').exists() || !data.exists()"
      }
    }
  }
}
